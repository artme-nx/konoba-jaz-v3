{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "dusk": {
        "950": { "$value": "#0E1A22", "$type": "color" },
        "900": { "$value": "#132732", "$type": "color" },
        "800": { "$value": "#1B3A47", "$type": "color" },
        "700": { "$value": "#284F5D", "$type": "color" }
      },
      "bay": {
        "600": { "$value": "#1F6E7A", "$type": "color" },
        "500": { "$value": "#2E8C93", "$type": "color" },
        "400": { "$value": "#4CACA6", "$type": "color" },
        "300": { "$value": "#7ECBBE", "$type": "color" }
      },
      "amber": {
        "600": { "$value": "#B5501F", "$type": "color" },
        "500": { "$value": "#D97B34", "$type": "color" },
        "400": { "$value": "#E8A559", "$type": "color" },
        "300": { "$value": "#F0C98A", "$type": "color" }
      },
      "sand": {
        "100": { "$value": "#F6EEDD", "$type": "color" },
        "300": { "$value": "#E5D6B8", "$type": "color" },
        "500": { "$value": "#B9A87E", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-fraunces), 'Fraunces', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-manrope), system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-geist-mono), 'SF Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.2s", "$type": "duration" },
        "drift": { "$value": "2.4s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "tide": { "$value": "cubic-bezier(0.45, 0, 0.25, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.02em", "$type": "dimension" },
      "label": { "$value": "0.22em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.dusk.950}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "card": { "$value": "{primitive.color.dusk.900}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "popover": { "$value": "{primitive.color.dusk.900}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "primary": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.dusk.950}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.dusk.800}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "muted": { "$value": "{primitive.color.dusk.900}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.sand.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.dusk.800}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.amber.600}", "$type": "color" },
    "border": { "$value": "{primitive.color.dusk.700}", "$type": "color" },
    "input": { "$value": "{primitive.color.dusk.700}", "$type": "color" },
    "ring": { "$value": "{primitive.color.amber.500}", "$type": "color" },
    "radius": { "$value": "0.25rem", "$type": "dimension" },
    "amber": { "$value": "{primitive.color.amber.500}", "$type": "color" },
    "amber-dim": { "$value": "{primitive.color.amber.600}", "$type": "color" },
    "bay": { "$value": "{primitive.color.bay.500}", "$type": "color" },
    "bay-bright": { "$value": "{primitive.color.bay.300}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.dusk.700}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-tide": { "$value": "{primitive.motion.ease.tide}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "canvas": {
      "sunset-stop-1": { "$value": "{primitive.color.dusk.950}", "$type": "color" },
      "sunset-stop-2": { "$value": "{primitive.color.amber.600}", "$type": "color" },
      "sunset-stop-3": { "$value": "{primitive.color.bay.600}", "$type": "color" },
      "sunset-stop-4": { "$value": "{primitive.color.dusk.950}", "$type": "color" }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.sand.100}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.dusk.950}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.amber.500}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.dusk.950}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.dusk.700}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.sand.500}", "$type": "color" }
    }
  }
}
